   "source": [
    "my_list = [12, 5, 8, 17, 3, 20, 11, 42, 9]\n",
    "\n",
    "print(\"Even numbers:\")\n",
    "for num in my_list:\n",
    "    if num % 2 == 0:\n",
    "        print(num, end=\" \")\n",
    "\n",
    "print(\"\\n\\nOdd numbers:\")\n",
    "for num in my_list:\n",
    "    if num % 2 != 0:\n",
    "        print(num, end=\" \")"
   ]
